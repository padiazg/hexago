package health

import (
	"net/http"

	"{{.ModuleName}}/internal/observability"
	"{{.ModuleName}}/pkg/logger"
	"{{.ModuleName}}/pkg/server"
)

// Config holds the configuration for the health handler.
type Config struct {
	Path          string
	Mux           *http.ServeMux
	HealthChecker *observability.HealthChecker
	Logger        logger.Logger
}

type handler struct {
	*Config
}

// New creates a new health handler.
func New(config *Config) *handler {
	if config.HealthChecker == nil {
		config.HealthChecker = observability.NewHealthChecker(config.Logger)
	}

	return &handler{Config: config}
}

// Configure registers the health routes on the ServeMux.
func (h *handler) Configure(srv server.Server) {
	h.Mux.Handle(h.Path, h.HealthChecker.HTTPHandler())
	h.Mux.Handle(h.Path+"/ready", h.HealthChecker.ReadinessHandler())
	h.Mux.Handle(h.Path+"/live", observability.LivenessHandler())
}
